root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4

[{*.yml,*.yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[{*.xml,pom.xml}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 2

[mvnw]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 2
